  "authors": [],
  "contact": {},
  "license": "AGPL-3.0",
  "icon": "assets/ping-player-name-and-spr-display/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "kun.client.PingPlayerNameAndSprDisplayClient"
    ],
    "main": [
      "kun.PingPlayerNameAndSprDisplay"
    ]
  },
  "mixins": [
    "ping-player-name-and-spr-display.mixins.json",
    {
      "config": "ping-player-name-and-spr-display.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
